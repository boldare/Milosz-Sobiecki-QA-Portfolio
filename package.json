{
  "name": "playwright-portfolio",
  "version": "1.0.0",
  "author": "Miłosz Sobiecki",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "test:smoke": "playwright test --grep @smoke",
    "test:ui:tag": "playwright test --grep @ui",
    "test:api": "playwright test --grep @api",
    "test:a11y": "playwright test --grep @a11y",
    "test:perf": "playwright test --grep @perf",
    "test:mock": "playwright test --grep @mock",
    "test:auth": "RUN_AUTH_SETUP=true playwright test --project=authenticated",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install",
    "clean": "rm -rf playwright-report test-results artifacts tests/.auth"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@faker-js/faker": "^9.6.0",
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.5",
    "zod": "^3.24.2",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
